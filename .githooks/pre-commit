#!/usr/bin/env bash
# Pre-commit hook for AMP SDK
# Runs gitleaks and security checks before each commit

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# ============================================
# 1. Gitleaks - Secret Detection
# ============================================
echo -n "  Checking for secrets (gitleaks)... "

if command -v gitleaks &> /dev/null; then
  if ! gitleaks protect --staged --config .gitleaks.toml --no-banner 2>/dev/null; then
    echo -e "${RED}FAILED${NC}"
    echo -e "${RED}Secrets detected in staged files! Review the output above.${NC}"
    echo -e "${YELLOW}If this is a false positive, add it to .gitleaks.toml allowlist.${NC}"
    exit 1
  fi
  echo -e "${GREEN}OK${NC}"
else
  echo -e "${YELLOW}SKIPPED (gitleaks not installed)${NC}"
  echo -e "${YELLOW}  Install: https://github.com/gitleaks/gitleaks#installing${NC}"
fi

# ============================================
# 2. Check for common sensitive files
# ============================================
echo -n "  Checking for sensitive files... "

SENSITIVE_PATTERNS=(
  "\.env$"
  "\.env\.local$"
  "\.env\.production$"
  "credentials\.json$"
  "service[_-]?account.*\.json$"
  "\.pem$"
  "\.key$"
  "\.p12$"
  "\.pfx$"
  "id_rsa"
  "id_ed25519"
  "\.npmrc$"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
FOUND_SENSITIVE=false

for pattern in "${SENSITIVE_PATTERNS[@]}"; do
  if echo "$STAGED_FILES" | grep -qiE "$pattern"; then
    if [ "$FOUND_SENSITIVE" = false ]; then
      echo -e "${RED}FAILED${NC}"
      FOUND_SENSITIVE=true
    fi
    echo -e "${RED}  Sensitive file detected: $(echo "$STAGED_FILES" | grep -iE "$pattern")${NC}"
  fi
done

if [ "$FOUND_SENSITIVE" = true ]; then
  echo -e "${RED}Remove sensitive files from staging before committing.${NC}"
  echo -e "${YELLOW}Use: git reset HEAD <file>${NC}"
  exit 1
fi
echo -e "${GREEN}OK${NC}"

# ============================================
# 3. Check for hardcoded IPs/internal hostnames
# ============================================
echo -n "  Checking for hardcoded internal addresses... "

STAGED_DIFF=$(git diff --cached --diff-filter=ACM -U0 2>/dev/null || true)

# Check for internal IPs (10.x, 172.16-31.x, 192.168.x) excluding common test/doc patterns
if echo "$STAGED_DIFF" | grep -E '^\+' | grep -v '^\+\+\+' | grep -qE '(10\.[0-9]+\.[0-9]+\.[0-9]+|172\.(1[6-9]|2[0-9]|3[01])\.[0-9]+\.[0-9]+|192\.168\.[0-9]+\.[0-9]+)' 2>/dev/null; then
  echo -e "${YELLOW}WARNING${NC}"
  echo -e "${YELLOW}  Internal IP addresses found in staged changes. Verify these are intentional.${NC}"
else
  echo -e "${GREEN}OK${NC}"
fi

# ============================================
# 4. Check for large files
# ============================================
echo -n "  Checking for large files (>1MB)... "

LARGE_FILE_FOUND=false
for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    FILE_SIZE=$(wc -c < "$file" 2>/dev/null || echo 0)
    if [ "$FILE_SIZE" -gt 1048576 ]; then
      if [ "$LARGE_FILE_FOUND" = false ]; then
        echo -e "${YELLOW}WARNING${NC}"
        LARGE_FILE_FOUND=true
      fi
      SIZE_MB=$(echo "scale=2; $FILE_SIZE / 1048576" | bc 2>/dev/null || echo "?")
      echo -e "${YELLOW}  Large file: $file (${SIZE_MB}MB)${NC}"
    fi
  fi
done

if [ "$LARGE_FILE_FOUND" = false ]; then
  echo -e "${GREEN}OK${NC}"
fi

echo -e "${GREEN}All pre-commit checks passed!${NC}"
exit 0
