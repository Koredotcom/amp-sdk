{
  "name": "@koreaiinc/amp-sdk-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "AMP SDK workspace - Agent Management Platform",
  "scripts": {
    "test": "cd packages/core && npx jest",
    "test:otel": "cd packages/otel-exporter && npx jest",
    "test:all": "npm run test && npm run test:otel",
    "lint": "cd packages/core && npx eslint src/",
    "build": "node scripts/build.js core",
    "build:otel": "node scripts/build.js otel-exporter",
    "build:all": "node scripts/build.js all",
    "sync-assets": "cp README.md packages/core/README.md && cp -r examples packages/core/",
    "prepublish": "npm run sync-assets",
    "publish:npm": "npm run sync-assets && cd packages/core && npm publish",
    "example:demo": "npx tsx examples/sdk-demo-test.ts",
    "example:llm": "npx tsx examples/llm-span.ts",
    "example:agent": "npx tsx examples/agent-span.ts",
    "example:tool": "npx tsx examples/tool-span.ts",
    "example:rag": "npx tsx examples/rag-span.ts",
    "example:workflow": "npx tsx examples/workflow-span.ts",
    "example:decorators": "npx tsx examples/decorator-example.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "amp",
    "agent-management-platform",
    "observability",
    "telemetry",
    "opentelemetry",
    "ai",
    "llm",
    "sdk",
    "kore"
  ],
  "author": "Kore.ai",
  "license": "MIT"
}

